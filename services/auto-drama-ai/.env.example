# Seedance / 火山方舟 API（复制为 .env 并填写）
# 勿将真实密钥提交到 Git

# Seedance API Key（方舟控制台）
SEEDANCE_API_KEY=

# 方舟 OpenAPI Base URL
VOLC_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 内容生成任务路径（一般无需修改）
VOLC_VIDEO_CREATE_PATH=/contents/generations/tasks
VOLC_VIDEO_GET_PATH=/contents/generations/tasks/{id}
# 取消/删除：DELETE .../contents/generations/tasks/{id}
# https://www.volcengine.com/docs/82379/1521720?lang=zh
VOLC_VIDEO_CANCEL_PATH=/contents/generations/tasks/{id}

# 模型接入点 Endpoint ID（控制台「推理接入」）
# 当前仅使用 Seedance 1.5 Pro
VOLC_SEEDANCE_PRO_MODEL=

# HTTP 网关（Next 设置 PY_GATEWAY_URL=http://127.0.0.1:8799 时分步：POST 创建 + GET 查询）
# PY_GATEWAY_HOST=127.0.0.1
# PY_GATEWAY_PORT=8799
# PY_GATEWAY_CORS=http://localhost:5173,http://localhost:5179

# 与文档一致：创建任务时可选顶层参数（见 https://www.volcengine.com/docs/82379/1521309 ）
# SEEDANCE_POLL_TIMEOUT_S=600
# VOLC_SEEDANCE_CALLBACK_URL=
# VOLC_SEEDANCE_GENERATE_AUDIO=0
# VOLC_SEEDANCE_WATERMARK=0
# VOLC_SEEDANCE_FPS=24
# VOLC_SEEDANCE_RETURN_LAST_FRAME=0

# 每日配额（预估 token 上限）
DAILY_QUOTA=4000000

# 配额持久化文件（相对仓库根目录运行 Node 时默认可写在 AI 包目录）
QUOTA_FILE=quota_stats.json
