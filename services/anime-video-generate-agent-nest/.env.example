# 本地生成 .env：在本包目录执行 pnpm run env:init（从本文件复制；若已有 .env 则跳过，不会覆盖）
# 亦可手动复制本文件为 .env，内容与接入点以你维护的本文件为准。
# 若仍报未读到 VOLC_CHAT_MODEL_*：启动前设 AUTO_DRAMA_ENV_DEBUG=1，控制台会提示是否读到 PRO（不打印密钥）。

# 复制为 services/anime-video-generate-agent-nest/.env 或与 services/anime-video-generate-agent-ai/.env 合并使用（AppModule 会加载相邻 AI 包 .env）

SEEDANCE_API_KEY=
VOLC_ARK_BASE_URL=

# --- 方舟扩展 API（可选；需在业务里注入 VolcArkAdvancedService 后自行调用）---
# 上下文缓存创建路径（默认 context/caching）；对话：context/chat/completions
# VOLC_ARK_CONTEXT_CREATE_PATH=context/caching
# VOLC_ARK_CONTEXT_CHAT_PATH=context/chat/completions
# 上传文件 POST 路径（默认 files）；purpose 默认 user_data
# VOLC_ARK_FILES_PATH=files
# VOLC_ARK_FILE_PURPOSE=user_data
# Responses API（默认 responses）
# VOLC_ARK_RESPONSES_PATH=responses

# --- Seedance 视频（内容生成 tasks）---
# 主线路：1.5 Pro Endpoint
VOLC_SEEDANCE_PRO_MODEL=
# 主线路额度/限流失败时降级（如 Seedance 1.0 Pro）
VOLC_SEEDANCE_FALLBACK_MODEL=

# --- 对话 API（结构化分镜 / LangChain Agent）---
# 文档: https://www.volcengine.com/docs/82379/1494384
# Pro → Lite → Mini 自动降级（同一 SEEDANCE_API_KEY）
VOLC_CHAT_MODEL_PRO=
VOLC_CHAT_MODEL_LITE=
VOLC_CHAT_MODEL_MINI=
# 对话接入点不支持 response_format（json_object/json_schema）时设 1：不再先发一次 400 再重试
# VOLC_CHAT_SKIP_RESPONSE_FORMAT=1

# --- 图片生成 Seedream（占位调用 VolcImageService）---
# 文档: https://www.volcengine.com/docs/82379/1541523
VOLC_IMAGE_MODEL_SEEDREAM=
# VOLC_IMAGE_GENERATIONS_PATH=/images/generations

# --- 分词（可选，RAG 切块参考）---
# 文档: https://www.volcengine.com/docs/82379/1528728
# VOLC_TOKENIZATION_MODEL=

# --- Agent 编排 ---
# on：有 script 时走 LangChain Runnable（导演→分镜→质检）；off：仅用本地 refine
VOLC_AGENT_PIPELINE=
# 使用 LangGraph StateGraph 编排（导演→分镜→质检→一致性审计→可选补救回路）；未设则仍走线性 Runnable
# VOLC_AGENT_LANGGRAPH=1
# 审计不通过时，允许「仅重跑分镜+质检」的最大轮数（0=只审计不重试）
# VOLC_AGENT_GRAPH_MAX_REPAIRS=1
# 一致性审计在启发式（如进化链漏形态）之外，再调用一次对话模型做 JSON 判定（多一次 token）
# VOLC_AGENT_CONSISTENCY_AUDIT_LLM=1
# VOLC_AGENT_PIPELINE_DISABLE=1
# 同一次拆镜请求内用方舟上下文缓存（common_prefix）减少重复传剧本/RAG；创建失败自动回退普通 chat
# VOLC_AGENT_CONTEXT_CACHE=1
# VOLC_AGENT_CONTEXT_CACHE_DISABLE=1
# 缓存 TTL（秒），文档允许约 3600～604800
# VOLC_CHAT_CONTEXT_TTL=3600
# 跨请求复用 context（客户端传 contextCacheKey）；默认开，显式关：VOLC_AGENT_CONTEXT_CACHE_REUSE_DISABLE=1
# VOLC_AGENT_CONTEXT_CACHE_REUSE=1
# 服务端会话表最大条数（LRU）
# VOLC_CONTEXT_CACHE_STORE_MAX=500
# 关闭「剧本意图识别」单独对话请求（省一次模型调用）：1 关闭
# VOLC_SCRIPT_INTENT_DISABLE=
# 静态 RAG 片段（向量检索可在上层注入 body.ragContext 后续扩展）
# AGENT_RAG_CONTEXT_SNIPPET=

# --- 分镜条数与剧本长度（省 token）---
# ARK_STORYBOARD_MIN_SHOTS=3
# ARK_STORYBOARD_MAX_SHOTS=12
# 单次请求「拆镜上限」绝对封顶（客户端可选更高档时被 clamp 到此值；默认 30）
# ARK_STORYBOARD_ABS_MAX_SHOTS=30
# ARK_STORYBOARD_MAX_SCRIPT_CHARS=12000
# 进化纪录片式兜底拆镜时每镜默认时长（秒，2–12）
# ARK_EVOLUTION_SHOT_DURATION_SEC=5
